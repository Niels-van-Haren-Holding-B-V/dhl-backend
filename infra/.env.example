# Secrets for the demo "production" server (always runs the sim machine).
# Copy to .env, fill in, never commit .env.
DB_PASSWORD=change-me
KEYCLOAK_ADMIN_PASSWORD=change-me
# Client secret of dhl-backend in the locker realm (realm import reads it from the env)
LOCKER_CLIENT_SECRET=change-me
# Password of the demo courier user (referenced by the realm import)
DEMO_USER_PASSWORD=change-me
# GHCR pull credentials (a PAT with read:packages)
GHCR_USERNAME=your-github-user
GHCR_PAT=
